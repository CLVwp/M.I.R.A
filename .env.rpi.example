# === Raspberry Pi (racine du dépôt M.I.R.A) ===
# Copier vers .env sur la Pi :
#   cp .env.rpi.example .env
#
# Puis :
#   docker compose -f docker-compose.rpi.yml up -d

# IP du PC où tourne Ollama (hotspot Windows vers la Pi ≈ souvent 192.168.137.1)
OLLAMA_PC_HOST=192.168.137.1

# Port Ollama sur ce PC (doit correspondre à OLLAMA_HOST_PORT du .env du PC)
OLLAMA_PC_PORT=11434

# Modèle Ollama utilisé par le STT (doit exister sur le PC : ollama list)
OLLAMA_MODEL=mira

# Identifiant MQTT du robot (identique pour STT, rpi-agent, topics mira/robots/<id>/…)
ROBOT_ID=mira-robot

# 1 = position simulée ; 0 = NMEA sur le port série (compose : /dev/ttyUSB0 → /dev/gps0)
# Sans dongle USB : MOCK_GPS=1 et commenter le bloc `devices:` de mira-rpi-agent dans docker-compose.rpi.yml
MOCK_GPS=0
GPS_SERIAL=/dev/gps0
GPS_BAUD=9600
# Devices host (Pi) -> conteneurs. Adapter selon ls -l /dev/serial/by-id/
HOST_GPS_DEV=/dev/ttyUSB0
HOST_ESP32_DEV=/dev/serial/by-id/usb-Silicon_Labs_CP2102_USB_to_UART_Bridge_Controller_0001-if00-port0

# Tant que le GPS n’a pas de fix, la carte utilise ce point (voir aussi compose LAT/LON)
# LAT=48.869867
# LON=2.307077

# Flux MJPEG servi par le conteneur mira-vision (même IP que la Pi, port = VISION_MJPEG_PORT).
# Exemple hotspot : remplace par l’IP réelle de ta Raspberry.
RPI_STREAM_URL=http://192.168.137.77:8080/stream

# Port hôte mappé sur le MJPEG de mira-vision (doit correspondre à l’URL ci-dessus)
VISION_MJPEG_PORT=8080

# 0 pour désactiver le serveur MJPEG dans vision.py
# STREAM_MJPEG_ENABLE=1

# --- Fluidité du flux MJPEG (mira-vision) ---
# Pause entre deux images (secondes) ; plus bas = plus d’images/s (défaut compose 0.04)
# STREAM_FRAME_MIN_INTERVAL_SEC=0.03
# Qualité JPEG 40–95 (plus bas = fichier plus léger, plus fluide sur le réseau)
# STREAM_JPEG_QUALITY=68
# Largeur max en pixels (0 = pas de redimensionnement ; 720 ou 640 pour alléger)
# STREAM_PREVIEW_MAX_WIDTH=720
# Pause boucle vision+détection (secondes) ; plus bas = boucle plus rapide (défaut 0.05)
# VISION_LOOP_SLEEP_SEC=0.033

# 1 = dessiner boîtes + labels COCO sur le flux MJPEG (0 = image brute seule)
# STREAM_DRAW_DETECTIONS=1

# mira-vision utilise le même ROBOT_ID que l’agent (topic mira/robots/<id>/vision/text pour le dashboard / LLM)
