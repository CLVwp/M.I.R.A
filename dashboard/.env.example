# Copier vers .env — toutes les commandes utilisent Bun uniquement.
BETTER_AUTH_SECRET=remplacer-par-une-chaine-32-caracteres-minimum
BETTER_AUTH_URL=http://localhost:3000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_PATH=./data/auth.sqlite
MQTT_URL=mqtt://127.0.0.1:1883
# Optionnel : User-Agent pour Nominatim (géocodage inverse → rue/ville dans le chat). Désactiver : NOMINATIM_DISABLE=1
# NOMINATIM_USER_AGENT=MIRA-Dashboard/1.0 (votre@email)
# Si la vision publie seulement sur mira/vision/output : robot id pour rattacher ces messages (défaut mira-robot)
# MQTT_LEGACY_VISION_ROBOT_ID=mira-robot
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=mira
PORT=3000
NODE_ENV=development
