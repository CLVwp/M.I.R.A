# === PC (racine du dépôt M.I.R.A) ===
# Copier vers .env sur la machine où tu lances Ollama :
#   copy .env.pc.example .env   (Windows)
#   cp .env.pc.example .env     (Linux / Pi si tu y lances aussi la stack PC)
#
# Puis :
#   docker compose -f docker-compose.pc.yml up -d

# Port exposé sur l’hôte pour Ollama (dashboard : OLLAMA_URL=http://127.0.0.1:<port>)
OLLAMA_HOST_PORT=11434
